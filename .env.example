# MoySklad MCP — environment example (OPTIONAL).
# The primary credential store is ~/.moysklad-mcp/cabinets.json (set by
# install.py). These env vars are a fallback / dev convenience.

# Personal access token: MoySklad → Настройки → Пользователи → Токены доступа.
# Never commit a real token. Cabinet store takes priority over this var.
MOYSKLAD_TOKEN=

# Writes are OFF by default. Set to 1 to allow create/post/delete of documents.
# Point ONLY at a TEST cabinet — never production books.
MOYSKLAD_ALLOW_WRITE=

# Optional: restrict writes to named cabinets (comma-separated, exact names).
# Leave empty for env-token installs (an allowlist with no active cabinet blocks all writes).
MOYSKLAD_WRITE_CABINETS=
